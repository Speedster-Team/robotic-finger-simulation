<launch>

  <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share finger_simulation)/config/base_sim.rviz" on_exit="shutdown" />  

  <node pkg="finger_simulation" exec="4barsim" on_exit="shutdown" output="screen"/>      

<node pkg="tf2_ros" exec="static_transform_publisher"
       args="--x -0.003 --y 0.040 --z -0.004 --qx 0 --qy 0 --qz 0 --qw 1 --frame-id speedster_finger/distal_phalanx --child-frame-id fingertip" />
                   
</launch>
