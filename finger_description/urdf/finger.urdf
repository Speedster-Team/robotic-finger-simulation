<?xml version="1.0"?>
<robot name="finger">

  <!-- Generated by blender_export.py from /home/michael-jenz/rds_ws/finger_vizualization/src/drake-finger-sim/blender_files/rds_finger2.blend -->

  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>
  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>
  <material name="purple">
    <color rgba="1 0 1 1"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>
  <material name="yellow">
    <color rgba="1 1 0 1"/>
  </material>

  <!-- Finger base -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://finger_description/meshes/visual/base_link.obj"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://finger_description/meshes/collision/col_base_link.obj"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05"/>
    </inertial>
  </link>

  <!-- Mcp Splay -->
  <joint name="mcp_splay" type="revolute">
    <parent link="base_link"/>
    <child link="mcp_link"/>
    <origin xyz="0.0 0.0196 0.017" rpy="0 0 0"/>
    <axis xyz="0.0 0.0 1.0"/>
    <limit lower="-0.174533" upper="0.174533" effort="5.0" velocity="3.14"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <!-- Space between MCP splay and flexion -->
  <link name="mcp_link">
    <visual>
      <geometry>
        <mesh filename="package://finger_description/meshes/visual/mcp_link.obj"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://finger_description/meshes/collision/col_mcp_link.obj"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05"/>
    </inertial>
  </link>

  <!-- Mcp Flexion -->
  <joint name="mcp_flexion" type="revolute">
    <parent link="mcp_link"/>
    <child link="proximal_phalanx"/>
    <origin xyz="-0.0 0.0177 0.0" rpy="0 0 0"/>
    <axis xyz="-1.0 0.0 0.0"/>
    <limit lower="0" upper="1.57" effort="5.0" velocity="3.14"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <!-- Proximal phalanx -->
  <link name="proximal_phalanx">
    <visual>
      <geometry>
        <mesh filename="package://finger_description/meshes/visual/proximal_phalanx.obj"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://finger_description/meshes/collision/col_proximal_phalanx.obj"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05"/>
    </inertial>
  </link>

  <!-- Pip Flexion -->
  <joint name="pip_flexion" type="revolute">
    <parent link="proximal_phalanx"/>
    <child link="middle_phalanx"/>
    <origin xyz="-0.0001 0.0612 -0.0017" rpy="0 0 0"/>
    <axis xyz="-1.0 0.0 0.0"/>
    <limit lower="0.0" upper="1.57" effort="5.0" velocity="3.14"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <!-- Middle phalanx -->
  <link name="middle_phalanx">
    <visual>
      <geometry>
        <mesh filename="package://finger_description/meshes/visual/middle_phalanx.obj"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://finger_description/meshes/collision/col_middle_phalanx.obj"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.008"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="5e-06" ixy="0" ixz="0" iyy="5e-06" iyz="0" izz="5e-06"/>
    </inertial>
  </link>

  <!-- Dip Flexion -->
  <joint name="dip_flexion" type="revolute">
    <parent link="middle_phalanx"/>
    <child link="distal_phalanx"/>
    <origin xyz="0.0036 0.0406 -0.0023" rpy="0 0 0"/>
    <axis xyz="-1.0 0.0 0.0"/>
    <limit lower="0.0" upper="1.57" effort="3.0" velocity="3.14"/>
    <dynamics damping="0.1" friction="0.0"/>
    <mimic joint="pip_flexion" multiplier="0.85" offset="0.0"/>
  </joint>

  <!-- Distal phalanx -->
  <link name="distal_phalanx">
    <visual>
      <geometry>
        <mesh filename="package://finger_description/meshes/visual/distal_phalanx.obj"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://finger_description/meshes/collision/col_distal_phalanx.obj"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="2e-06" ixy="0" ixz="0" iyy="2e-06" iyz="0" izz="2e-06"/>
    </inertial>
  </link>

</robot>