<launch>
  <node pkg="robot_state_publisher" exec="robot_state_publisher">
    <param name="robot_description" value="$(command '$(exec-in-pkg xacro xacro) $(find-pkg-share finger_description)/urdf/finger.urdf gazebo:=true')" />
  </node>

  <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui"/>   

  <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share finger_description)/config/config.rviz" on_exit="shutdown" />                         

</launch>
