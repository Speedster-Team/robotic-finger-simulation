<launch>
  <arg name="use_rviz" default="true" description="Enable the use of rviz for visualization.">
    <choice value="true" />
    <choice value="false" />
  </arg>

  <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share finger_simulation)/config/base_sim.rviz" if="$(eval '\'$(var use_rviz)\'==\'true\'')" on_exit="shutdown"/>  

  <node pkg="finger_simulation" exec="basic"/>

  <node pkg="finger_bridge" exec="simulation_bridge"/>

  <node pkg="finger_planner" exec="finger_planner">
    <param from="$(find-pkg-share finger_planner)/config/movement_config.yaml"/>
  </node>

  <node pkg="finger_control" exec="finger_control"/>

</launch>
